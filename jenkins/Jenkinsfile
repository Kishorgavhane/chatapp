// ChatApp — Jenkins CD Pipeline
// Triggered by GitHub Actions after successful CI + Trivy scan.
// Flow: Ansible pre-deploy → Terraform EKS → ArgoCD sync → Smoke test → Jira close

pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG',    defaultValue: 'latest',  description: 'Docker image tag from CI')
        string(name: 'TARGET_ENV',   defaultValue: 'staging', description: 'staging | production')
    }

    environment {
        AWS_REGION        = 'us-east-1'
        EKS_CLUSTER_NAME  = "chatapp-${params.TARGET_ENV}"
        ARGOCD_SERVER     = credentials('argocd-server-url')
        ARGOCD_AUTH_TOKEN = credentials('argocd-auth-token')
        JIRA_BASE_URL     = credentials('jira-base-url')
        JIRA_TOKEN        = credentials('jira-api-token')
        SLACK_CHANNEL     = '#deployments'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/YOUR_ORG/chatapp.git'
                echo "Deploying tag: ${params.IMAGE_TAG} → ${params.TARGET_ENV}"
            }
        }

        // ── Ansible: pre-deploy tasks ─────────────────────────────────────
        stage('Ansible: Pre-Deploy') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'ansible-ssh-key', keyFileVariable: 'SSH_KEY')]) {
                    sh """
                        cd ansible
                        ansible-playbook \
                          -i inventories/${params.TARGET_ENV}.ini \
                          playbooks/pre-deploy.yml \
                          --private-key \$SSH_KEY \
                          -e "env=${params.TARGET_ENV} image_tag=${params.IMAGE_TAG}"
                    """
                }
            }
        }

        // ── Terraform: provision / update EKS infra ───────────────────────
        stage('Terraform: Apply') {
            steps {
                withAWS(credentials: 'aws-chatapp', region: env.AWS_REGION) {
                    dir('terraform') {
                        sh """
                            terraform init -input=false
                            terraform workspace select ${params.TARGET_ENV} || terraform workspace new ${params.TARGET_ENV}
                            terraform plan -out=tfplan \
                              -var="env=${params.TARGET_ENV}" \
                              -var="cluster_name=${env.EKS_CLUSTER_NAME}"
                            terraform apply -auto-approve tfplan
                        """
                    }
                }
            }
        }

        // ── Update kubeconfig ────────────────────────────────────────────
        stage('Kubeconfig') {
            steps {
                withAWS(credentials: 'aws-chatapp', region: env.AWS_REGION) {
                    sh "aws eks update-kubeconfig --name ${env.EKS_CLUSTER_NAME} --region ${env.AWS_REGION}"
                }
            }
        }

        // ── Update Helm image tag → git push (ArgoCD detects change) ─────
        stage('Update Image Tag') {
            steps {
                sh """
                    sed -i 's/tag:.*/tag: ${params.IMAGE_TAG}/' helm/chatapp/values.yaml
                    git config user.email "jenkins@ci.local"
                    git config user.name  "Jenkins"
                    git add helm/chatapp/values.yaml
                    git diff --staged --quiet || git commit -m "ci: bump image to ${params.IMAGE_TAG} [skip ci]"
                    git push origin main
                """
            }
        }

        // ── ArgoCD sync & wait ────────────────────────────────────────────
        stage('ArgoCD: Sync') {
            steps {
                sh """
                    argocd app sync chatapp \
                      --server \$ARGOCD_SERVER \
                      --auth-token \$ARGOCD_AUTH_TOKEN \
                      --timeout 300 --grpc-web

                    argocd app wait chatapp \
                      --server \$ARGOCD_SERVER \
                      --auth-token \$ARGOCD_AUTH_TOKEN \
                      --health --timeout 300 --grpc-web
                """
            }
        }

        // ── Smoke test ────────────────────────────────────────────────────
        stage('Smoke Test') {
            steps {
                sh """
                    INGRESS=\$(kubectl get ingress chatapp -n chatapp \
                      -o jsonpath='{.status.loadBalancer.ingress[0].hostname}')
                    echo "Testing http://\$INGRESS/health"
                    curl -f --retry 5 --retry-delay 5 "http://\$INGRESS/health" || exit 1
                    echo "Smoke test PASSED"
                """
            }
        }

        // ── Jira: auto-close tickets from commit messages ─────────────────
        stage('Jira: Close Tickets') {
            steps {
                script {
                    def tickets = sh(
                        script: "git log --oneline -10 | grep -oE 'CHAT-[0-9]+' | sort -u || true",
                        returnStdout: true
                    ).trim()

                    if (tickets) {
                        tickets.split('\n').each { ticket ->
                            sh """
                                curl -s -X POST \
                                  "\$JIRA_BASE_URL/rest/api/3/issue/${ticket}/transitions" \
                                  -H "Authorization: Bearer \$JIRA_TOKEN" \
                                  -H "Content-Type: application/json" \
                                  -d '{"transition":{"id":"31"}}'
                            """
                            echo "Closed Jira ticket: ${ticket}"
                        }
                    } else {
                        echo "No Jira tickets in recent commits."
                    }
                }
            }
        }
    }

    post {
        success {
            slackSend channel: env.SLACK_CHANNEL, color: 'good',
                message: "✅ ChatApp ${params.TARGET_ENV} deployed | tag=${params.IMAGE_TAG} | <${env.BUILD_URL}|Build #${env.BUILD_NUMBER}>"
        }
        failure {
            slackSend channel: env.SLACK_CHANNEL, color: 'danger',
                message: "❌ ChatApp ${params.TARGET_ENV} FAILED | tag=${params.IMAGE_TAG} | <${env.BUILD_URL}|Build #${env.BUILD_NUMBER}>"
        }
        always {
            cleanWs()
        }
    }
}
