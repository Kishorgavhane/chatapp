cat > .gitignore << 'EOF'
# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
.terraform.lock.hcl

# Ansible
*.retry

# Docker
.dockerignore

# OS
.DS_Store
*.log

# Secrets —
*.pem
*.key
secrets/
.env

echo "node_modules/" >> .gitignore
echo "__pycache__/" >> .gitignore
echo "*.pyc" >> .gitignore
node_modules/
dist/
EOF
node_modules/
__pycache__/
*.pyc
app/chatapp/frontend/node_modules/
app/chatapp/backend/__pycache__/
